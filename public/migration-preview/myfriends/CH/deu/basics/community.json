      "data": {
        "style": "ordered",
        "items": [
          "Was hast du diese Woche mit Gott erlebt?",
          "Wofür bist du dankbar?",
          "Wo brauchst du Gottes Hilfe?",
          "Wie kann dir praktisch geholfen werden?",
          "Betet für einander"
        ]
      }
