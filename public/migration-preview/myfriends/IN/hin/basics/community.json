    {
      "type": "list",
      "data": {
        "style": "ordered",
        "items": [
          "भगवान से पूछें कि वह क्या चाहता है कि आप पारित होने के जवाब में क्या करें। है: <ul><li>बदलने के लिए एक व्यवहार?</li><li>दावा करने का वादा?</li><li>एक पालन करने के लिए एक उदाहरण है?</li><li>आदेश का पालन करने के लिए?</li></ul>",
          "इस समूह के साथ साझा करें"
        ]
