{
  // ========== CACHE & EXPORT SETTINGS ==========
  "csvExportPath": "translator.csv",      // Path to export translation cache to CSV
  "autoExport": true,                     // Automatically export cache after translations
  "autoImport": true,                     // Automatically import from CSV on startup

  // ========== SOURCE & TARGET CONFIGURATION ==========
  "sourcePaths": ["i18n/en"],             // Paths to scan for source language files
  "sourceLocale": "en",                   // Source language code
  "targetLocales": ["es", "fr", "de", "ja", "zh-CN"], // Languages to translate to
  "enableBackTranslation": false,         // Enable back-translation for quality checks

  // ========== DEFAULT TRANSLATION ENGINES ==========
  "defaultMarkdownEngine": "azure",       // Engine for .md and .mdx files
  "defaultJsonEngine": "google",          // Engine for .json and .yaml files

  // ========== ENGINE OVERRIDES BY LANGUAGE ==========
  // Override the default engine for specific target languages
  "engineOverrides": {
    "deepl": ["fr", "de"],                // Use DeepL for French and German translation (back & forward)
    "azure": ["es:en", "ja:en"]           // Use Azure for Spanish and Japanese back translations
  },

  // ========== KEY EXCLUSION RULES ==========
  "excludeKeys": [],                      // Key names to exclude (matches at any depth)
  "excludeKeyPaths": [],                  // Exact dotted paths to exclude (e.g., "meta.version")
  "copyOnlyFiles": [],                    // Files to copy verbatim without translation

  // ========== TRANSLATION ENGINE CONFIGURATIONS ==========
  "translator": {
    // No-op translator - returns input unchanged
    "copy": {},

    // Google Cloud Translation API
    "google": {
      "apiKey": "${GOOGLE_TRANSLATION_KEY}",           // Service account JSON or file path
      "endpoint": "${GOOGLE_TRANSLATION_URL}",         // API endpoint
      "googleProjectId": "${GOOGLE_TRANSLATION_PROJECT_ID}",
      "googleLocation": "${GOOGLE_TRANSLATION_LOCATION}",

      // Locale mappings for Google Cloud Translation
      "langMap": {
        "zh-CN": "zh-cn",
        "zh-TW": "zh-tw",
        "zh-Hans": "zh-cn",
        "zh-Hant": "zh-tw"
      }
    },

    // Microsoft Azure Translator
    "azure": {
      "apiKey": "${AZURE_TRANSLATION_KEY}",
      "region": "${AZURE_TRANSLATION_REGION}",
      "endpoint": "${AZURE_TRANSLATION_URL}",

      // Locale mappings for Azure Translator
      "langMap": {
        "zh-CN": "zh-Hans",
        "zh-TW": "zh-Hant",
        "zh-HK": "zh-Hant",
        "fr-CA": "fr-ca",
        "iu-Latn": "iu-Latn",
        "mn": "mn-Cyrl",
        "mn-Cyrl": "mn-Cyrl",
        "mn-Mong": "mn-Mong",
        "pt-PT": "pt-PT",
        "pt": "pt-BR",
        "pt-BR": "pt-BR",
        "sr": "sr-Cyrl",
        "sr-Cyrl": "sr-Cyrl",
        "sr-Latn": "sr-Latn"
      }
    },

    // DeepL Translation API
    "deepl": {
      "apiKey": "${DEEPL_TRANSLATION_KEY}",
      "endpoint": "${DEEPL_TRANSLATION_URL}",

      // Locale mappings for DeepL (uses uppercase language codes)
      "langMap": {
        "ar": "AR",
        "bg": "BG",
        "cs": "CS",
        "da": "DA",
        "de": "DE",
        "el": "EL",
        "en": "EN",
        "es": "ES",
        "et": "ET",
        "fi": "FI",
        "fr": "FR",
        "hu": "HU",
        "id": "ID",
        "it": "IT",
        "ja": "JA",
        "ko": "KO",
        "lt": "LT",
        "lv": "LV",
        "nb": "NB",
        "nl": "NL",
        "pl": "PL",
        "pt": "PT",
        "pt-BR": "PT-BR",
        "pt-PT": "PT-PT",
        "ro": "RO",
        "ru": "RU",
        "sk": "SK",
        "sl": "SL",
        "sv": "SV",
        "tr": "TR",
        "uk": "UK",
        "zh": "ZH"
      }
    },

    // Google Gemini API (LLM-based translation)
    "gemini": {
      "apiKey": "${GEMINI_API_KEY}",
      "endpoint": "${GEMINI_API_URL}",

      // Locale mappings for Gemini (uses language names)
      "langMap": {
        "ar": "Arabic",
        "zh-CN": "Chinese (Simplified)",
        "zh-Hans": "Chinese (Simplified)",
        "zh-TW": "Chinese (Traditional)",
        "zh-Hant": "Chinese (Traditional)",
        "fr": "French",
        "de": "German",
        "hi": "Hindi",
        "it": "Italian",
        "ja": "Japanese",
        "ko": "Korean",
        "pt": "Portuguese",
        "ru": "Russian",
        "es": "Spanish"
      }
    },

    // OpenRouter API (supports multiple LLM models)
    "openrouter": {
      "apiKey": "${OPENROUTER_API_KEY}",
      "endpoint": "${OPENROUTER_API_URL}",

      // Locale mappings for OpenRouter
      "langMap": {
        "ar": "Arabic",
        "da": "Danish",
        "de": "German",
        "en-GB": "English (UK)",
        "en-US": "English",
        "es-419": "Spanish (Latin America)",
        "es-ES": "Spanish",
        "fi": "Finnish",
        "fr-CA": "French (Canada)",
        "fr-FR": "French",
        "hi-Latn-IN": "Hinglish",
        "hi": "Hindi",
        "it": "Italian",
        "ja": "Japanese",
        "ko": "Korean",
        "nl": "Dutch",
        "no": "Norwegian",
        "pl": "Polish",
        "pt-BR": "Portuguese (Brazil)",
        "pt-PT": "Portuguese (Portugal)",
        "ru": "Russian",
        "sv": "Swedish",
        "th": "Thai",
        "tr": "Turkish",
        "vi": "Vietnamese",
        "zh-CN": "Chinese (Simplified)",
        "zh-Hans": "Chinese (Simplified)",
        "zh-Hant": "Chinese (Traditional)",
        "zh-HK": "Chinese (Traditional)",
        "zh-TW": "Chinese (Traditional)"
      }
    }
  }
}
